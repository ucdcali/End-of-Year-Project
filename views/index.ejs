<!DOCTYPE html>
<html>
<head>
  <title>Daily Menu</title>
  <link rel="stylesheet" href="/styles.css" />
</head>

<body>
  <%- include('navbar') %>
  
  <main class="container">
    <h1>Today's Dish</h1>

    <% if (noMealToday) { %>
      <div class="no-meal-message">
        <p>No meal scheduled for today.</p>
      </div>
    <% } else if (mealInfo) { %>
      <section class="meal-display">
        <h2><%= mealInfo.title %></h2>
        <img src="<%= mealInfo.img %>" alt="<%= mealInfo.title %>" class="meal-image" />
        
        <% if (mealInfo.description) { %>
          <p class="meal-description"><%= mealInfo.description %></p>
        <% } %>
        
        <% if (mealInfo.diet && mealInfo.diet.length > 0) { %>
          <div class="dietary-info">
            <p><strong>Dietary Info:</strong></p>
            <ul>
              <% mealInfo.diet.forEach(d => { %>
                <li>
                  <% if (d === 'V') { %>V (Vegan)
                  <% } else if (d === 'VG') { %>VG (Vegetarian)
                  <% } else if (d === 'GF') { %>GF (Gluten-Free)
                  <% } else if (d === 'DF') { %>DF (Dairy-Free)
                  <% } else if (d === 'NF') { %>NF (Nut-Free)
                  <% } %>
                </li>
              <% }); %>
            </ul>
          </div>
        <% } %>
        
        <a href="/menu" class="btn btn-primary">View Full Monthly Menu</a>
      </section>
    <% } %>
  </main>

</body>
</html>