<!DOCTYPE html>
<html>
  <head>
    <title>Edit Menu</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include('navbar') %>

    <main class="container admin-container">
      <h1>Edit Menu</h1>
      <p>Update meals for each day of the <strong><%= menu.month.charAt(0).toUpperCase() + menu.month.slice(1) %> <%= menu.year %></strong> menu.</p>

      <form action="/admin/editMenu/<%= menu._id %>" method="post" class="menu-form">
        <div class="form-group">
          <label for="month">Month:</label>
          <select name="month" id="month" required>
            <% const monthNames = ['january','february','march','april','may','june','july','august','september','october','november','december']; %>
            <% monthNames.forEach(name => { %>
              <option value="<%= name %>" <%= menu.month === name ? 'selected' : '' %>><%= name.charAt(0).toUpperCase() + name.slice(1) %></option>
            <% }); %>
          </select>
        </div>

        <div class="form-group">
          <label for="year">Year:</label>
          <input name="year" id="year" type="number" min="2025" max="2099" value="<%= menu.year %>" required />
        </div>

        <div id="menu-days">
          <p>Select up to two meals for each day. Leave a meal slot blank if no meal is scheduled.</p>
          <div class="menu-day-grid">
            <% menuDays.forEach(item => { %>
              <div class="menu-day-select">
                <label for="meal_day_<%= item.day %>_1">Day <%= item.day %> - Meal 1</label>
                <select name="meal_day_<%= item.day %>_1" id="meal_day_<%= item.day %>_1">
                  <option value="">No meal</option>
                  <% allMeals.forEach(meal => { %>
                    <option value="<%= meal._id %>" <%= item.meal1Id === String(meal._id) ? 'selected' : '' %>><%= meal.title %></option>
                  <% }); %>
                </select>
              </div>
              <div class="menu-day-select">
                <label for="meal_day_<%= item.day %>_2">Day <%= item.day %> - Meal 2</label>
                <select name="meal_day_<%= item.day %>_2" id="meal_day_<%= item.day %>_2">
                  <option value="">No meal</option>
                  <% allMeals.forEach(meal => { %>
                    <option value="<%= meal._id %>" <%= item.meal2Id === String(meal._id) ? 'selected' : '' %>><%= meal.title %></option>
                  <% }); %>
                </select>
                <select name="meal2_day_<%= item.day %>" id="meal2_day_<%= item.day %>">
                  <option value="">No meal</option>
                  <% allMeals.forEach(meal => { %>
                    <option value="<%= meal._id %>" <%= item.mealId === String(meal._id) ? 'selected' : '' %>><%= meal.title %></option>
                  <% }); %>
                  </select>
                </div>
              </div>
            <% }); %>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Save Menu</button>
          <a href="/admin" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </main>
  </body>
</html>