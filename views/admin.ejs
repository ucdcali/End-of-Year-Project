<!DOCTYPE html>
<html>
  <head>
    <title>Admin - Menu Management</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include('navbar') %>
    
    <main class="container admin-container">
      <h1>Admin Dashboard</h1>
      <p>Welcome, Admin! Manage meals and monthly menus here.</p>

      <section id="addMenuItem">
        <h2>Create New Meal Item</h2>

        <form action="/admin/createMeal" method="post" class="meal-form">
          <div class="form-group">
            <label for="title">Meal Title</label>
            <input id="title" type="text" name="title" required />
          </div>

          <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" rows="4"></textarea>
          </div>

          <div class="form-group">
            <label for="img">Image URL</label>
            <input id="img" type="url" name="img" />
          </div>

          <div class="form-group">
            <label>Dietary Restrictions</label>
            <ul class="checkbox-list">
              <li>
                <input id="diet-V" type="checkbox" name="diet" value="V" />
                <label for="diet-V">Vegan</label>
              </li>
              <li>
                <input id="diet-VG" type="checkbox" name="diet" value="VG" />
                <label for="diet-VG">Vegetarian</label>
              </li>
              <li>
                <input id="diet-GF" type="checkbox" name="diet" value="GF" />
                <label for="diet-GF">Gluten-Free</label>
              </li>
              <li>
                <input id="diet-DF" type="checkbox" name="diet" value="DF" />
                <label for="diet-DF">Dairy-Free</label>
              </li>
              <li>
                <input id="diet-NF" type="checkbox" name="diet" value="NF" />
                <label for="diet-NF">Nut-Free</label>
              </li>
            </ul>
          </div>

          <button type="submit" class="btn btn-primary">Create Meal</button>
        </form>
      </section>

      <section id="mealsList">
        <h2>Existing Meals</h2>
        <% if (meals && meals.length > 0) { %>
          <table class="meals-table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Dietary Info</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% meals.forEach(meal => { %>
                <tr>
                  <td><%= meal.title %></td>
                  <td><%= meal.description || 'N/A' %></td>
                  <td>
                    <% if (meal.diet && meal.diet.length > 0) { %>
                      <%= meal.diet.join(', ') %>
                    <% } else { %>
                      None
                    <% } %>
                  </td>
                  <td>
                    <div class="actions-cell">
                      <a href="/meals/edit/<%= meal._id %>" class="btn btn-sm btn-info">Edit</a>
                      <form action="/meals/delete/<%= meal._id %>" method="post" class="inline-form delete-form" data-meal-title="<%= meal.title %>">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <p>No meals created yet.</p>
        <% } %>
      </section>

      <section id="menuList">
        <h2>Existing Menus</h2>
        <% if (menus && menus.length > 0) { %>
          <table class="meals-table">
            <thead>
              <tr>
                <th>Month</th>
                <th>Year</th>
                <th>Scheduled Days</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% menus.forEach(menu => { %>
                <tr>
                  <td><%= menu.month.charAt(0).toUpperCase() + menu.month.slice(1) %></td>
                  <td><%= menu.year %></td>
                  <td><%= menu.meals ? menu.meals.length : 0 %></td>
                  <td>
                    <a href="/admin/editMenu/<%= menu._id %>" class="btn btn-sm btn-info">Edit Menu</a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <p>No menus created yet.</p>
        <% } %>
      </section>

      <section id="menuManagement">
        <h2>Create Monthly Menu</h2>
        <p>Select meals for each day of the month. (This feature is under development)</p>
        
        <form action="/admin/createMenu" method="post" class="menu-form">
          <div class="form-group">
            <label for="month">Month:</label>
            <select name="month" id="month" required>
              <option disabled selected>Select Month</option>
              <option value="january">January</option>
              <option value="february">February</option>
              <option value="march">March</option>
              <option value="april">April</option>
              <option value="may">May</option>
              <option value="june">June</option>
              <option value="july">July</option>
              <option value="august">August</option>
              <option value="september">September</option>
              <option value="october">October</option>
              <option value="november">November</option>
              <option value="december">December</option>
            </select>
          </div>

          <div class="form-group">
            <label for="year">Year:</label>
            <% const currentYear = new Date().getFullYear(); %>
            <select name="year" id="year" required>
              <option value="<%= currentYear %>"><%= currentYear %></option>
              <option value="<%= currentYear + 1 %>"><%= currentYear + 1 %></option>
            </select>
          </div>

          <div id="menu-days">
            <p>Select a meal for each day of the month. Leave a day blank if there is no meal scheduled.</p>
            <div class="menu-day-grid">
              <% for (let day = 1; day <= 31; day++) { %>
                <div class="menu-day-select">
                  <label for="meal_day_<%= day %>">Day <%= day %></label>
                  <select name="meal_day_<%= day %>" id="meal_day_<%= day %>">
                    <option value="">No meal</option>
                    <% meals.forEach(meal => { %>
                      <option value="<%= meal._id %>"><%= meal.title %></option>
                    <% }); %>
                  </select>
                </div>
              <% } %>
            </div>
          </div>

          <button type="submit" class="btn btn-primary">Create Menu</button>
        </form>
      </section>
    </main>

    <div class="modal-overlay" id="deleteModal" aria-hidden="true">
      <div class="modal-dialog" role="dialog" aria-modal="true" aria-labelledby="deleteModalTitle">
        <h2 id="deleteModalTitle">Delete Meal</h2>
        <p id="deleteModalMessage">Are you sure you want to delete this meal?</p>
        <div class="modal-actions">
          <button class="btn btn-secondary" id="cancelDeleteBtn" type="button">Cancel</button>
          <button class="btn btn-danger" id="confirmDeleteBtn" type="button">Delete</button>
        </div>
      </div>
    </div>

    <script>
      const deleteModal = document.getElementById('deleteModal');
      const deleteMessage = document.getElementById('deleteModalMessage');
      const cancelDeleteBtn = document.getElementById('cancelDeleteBtn');
      const confirmDeleteBtn = document.getElementById('confirmDeleteBtn');
      let activeDeleteForm = null;

      document.querySelectorAll('.delete-form').forEach(form => {
        form.addEventListener('submit', event => {
          event.preventDefault();
          activeDeleteForm = form;
          const mealTitle = form.dataset.mealTitle || 'this meal';
          deleteMessage.textContent = `Delete ${mealTitle}? This action cannot be undone.`;
          deleteModal.classList.add('visible');
          deleteModal.setAttribute('aria-hidden', 'false');
        });
      });

      cancelDeleteBtn.addEventListener('click', () => {
        deleteModal.classList.remove('visible');
        deleteModal.setAttribute('aria-hidden', 'true');
        activeDeleteForm = null;
      });

      confirmDeleteBtn.addEventListener('click', () => {
        if (activeDeleteForm) {
          activeDeleteForm.submit();
        }
      });

      deleteModal.addEventListener('click', event => {
        if (event.target === deleteModal) {
          deleteModal.classList.remove('visible');
          deleteModal.setAttribute('aria-hidden', 'true');
          activeDeleteForm = null;
        }
      });
    </script>
  </body>
</html>